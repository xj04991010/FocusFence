<UserControl x:Class="FocusFence.Controls.PomodoroRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Viewbox Stretch="Uniform">
        <Grid Width="100" Height="100">
            <!-- Background circle (track) -->
            <Ellipse x:Name="TrackEllipse"
                     StrokeThickness="8"
                     Stroke="#15FFFFFF"
                     Fill="Transparent"/>

            <!-- Progress arc (drawn in code-behind via StreamGeometry) -->
            <Path x:Name="ProgressArc"
                  StrokeThickness="8"
                  Stroke="{DynamicResource AccentTealBrush}"
                  Fill="Transparent"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  RenderTransformOrigin="0.5,0.5">
                <Path.CacheMode>
                    <BitmapCache EnableClearType="False" RenderAtScale="1" SnapsToDevicePixels="False" />
                </Path.CacheMode>
                <Path.Effect>
                    <DropShadowEffect x:Name="ArcGlow" Color="#FF4EAEB5" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                </Path.Effect>
                <Path.RenderTransform>
                    <ScaleTransform x:Name="RingScale" ScaleX="1" ScaleY="1"/>
                </Path.RenderTransform>
            </Path>

            <!-- Center text: time remaining -->
            <TextBlock x:Name="TimeText"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif"
                       FontSize="26" FontWeight="Black"
                       Typography.NumeralAlignment="Tabular"/>
            
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18"
                       Text="MIN"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       FontFamily="Segoe UI"
                       FontSize="10" FontWeight="Bold"/>

        </Grid>
    </Viewbox>
</UserControl>
