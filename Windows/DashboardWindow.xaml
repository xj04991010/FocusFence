<Window x:Class="FocusFence.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="FocusFence" ShowInTaskbar="True" Topmost="True"
        Width="500" Height="620" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DesignTokens.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="PomoChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="0,8"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="TextBlock.Foreground" Value="White"/>
                <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Border CornerRadius="20" BorderThickness="1" Margin="10"
            BorderBrush="{StaticResource ZoneBorderBrush}"
            Effect="{StaticResource ShadowDeep}">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource BgBlurTint}"/>
        </Border.Background>
        <Grid x:Name="MainContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" CornerRadius="16,16,0,0" MouseLeftButtonDown="TitleBar_Drag">
                <Border.Background>
                    <LinearGradientBrush>
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0">
                    <TextBlock x:Name="DashboardTitleText" Text="📊 FocusFence 控制台" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Border Cursor="Hand" Padding="8,4" MouseLeftButtonDown="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent">
                        <TextBlock Text="✕" Foreground="#88FFFFFF" FontSize="12"/>
                    </Border>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,10,20,0">
                <Border x:Name="TabZones" Padding="12,6" CornerRadius="6" Background="#33C69C6D" Cursor="Hand" MouseLeftButtonDown="TabZones_Click"><TextBlock x:Name="TabZonesText" Text="🗂️ 框框" Foreground="White" FontSize="12" FontWeight="SemiBold"/></Border>
                <Border x:Name="TabPomodoro" Padding="12,6" Margin="8,0,0,0" CornerRadius="6" Background="Transparent" Cursor="Hand" MouseLeftButtonDown="TabPomodoro_Click"><TextBlock x:Name="TabPomodoroText" Text="🍅 專注" Foreground="#AAFFFFFF" FontSize="12" FontWeight="SemiBold"/></Border>
                <Border x:Name="TabNotes" Padding="12,6" Margin="8,0,0,0" CornerRadius="6" Background="Transparent" Cursor="Hand" MouseLeftButtonDown="TabNotes_Click"><TextBlock x:Name="TabNotesText" Text="📝 筆記" Foreground="#AAFFFFFF" FontSize="12" FontWeight="SemiBold"/></Border>
            </StackPanel>
            <Grid x:Name="ZonesContainer" Grid.Row="2" Grid.RowSpan="2" Margin="12">
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <ListBox Grid.Row="0" x:Name="ZoneListBox" Background="Transparent" BorderThickness="0" AllowDrop="True" PreviewMouseLeftButtonDown="ZoneList_PreviewMouseDown" PreviewMouseMove="ZoneList_PreviewMouseMove" PreviewMouseLeftButtonUp="ZoneList_PreviewMouseUp" Drop="ZoneList_Drop" DragOver="ZoneList_DragOver">
                    <ListBox.Resources>
                        <ContextMenu x:Key="ZoneRowContextMenu"><MenuItem Header="呼叫" Click="ContextSummon_Click"/><MenuItem Header="開啟資料夾" Click="ContextOpenFolder_Click"/><Separator/><MenuItem Header="刪除" Click="ContextDelete_Click"/></ContextMenu>
                    </ListBox.Resources>
                    <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate></Setter.Value></Setter></Style></ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="12" Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#11FFFFFF" ContextMenu="{StaticResource ZoneRowContextMenu}" MouseLeftButtonDown="ZoneRow_DoubleClickSummon">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="12" Height="12" Fill="{Binding AccentColorBrush}" VerticalAlignment="Center" Margin="0,0,12,0" Cursor="Hand" MouseLeftButtonDown="DashColorDot_Click" Tag="{Binding .}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBox Text="{Binding Title}" Foreground="White" FontSize="13" Background="Transparent" BorderThickness="0" GotFocus="TitleTextBox_GotFocus" LostFocus="TitleTextBox_LostFocus" KeyDown="TitleTextBox_KeyDown"/>
                                        <TextBlock Text="{Binding FileCount}" Foreground="#88FFFFFF" FontSize="10"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Width="36" Height="18" CornerRadius="9" Background="{Binding ToggleBackground}" Cursor="Hand" MouseLeftButtonDown="ToggleSwitch_Click" Tag="{Binding .}"><Ellipse Width="14" Height="14" Fill="White" HorizontalAlignment="Left" Margin="{Binding ToggleKnobMargin}"/></Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border x:Name="DragIndicator" Grid.Row="0" Height="2" Background="Teal" VerticalAlignment="Top" Visibility="Collapsed"/>
                <Button Grid.Row="1" Content="+ 新增框框" Click="NewZone_Click" Background="#33C69C6D" Foreground="White" BorderThickness="0" Padding="16,8" Margin="0,8,0,0"/>
            </Grid>
            <Grid x:Name="PomodoroContainer" Grid.Row="2" Grid.RowSpan="2" Visibility="Collapsed" Margin="20,16">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#15FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="🎯 本週進度" Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="今日 🍅" Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="TodayTomatoCount" Text="0" Foreground="#C69C6D" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                        <ProgressBar x:Name="WeekTomatoProgressBar" Height="8" Maximum="21" Background="#11FFFFFF" Foreground="#C69C6D"/>
                        <TextBlock x:Name="WeekTomatoCountText" Text="0 / 21" Foreground="White" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <UniformGrid Columns="4"><Border x:Name="Chip15" Tag="15" Style="{StaticResource PomoChipStyle}" MouseLeftButtonDown="PomoChip_Click"><TextBlock Text="15m"/></Border><Border x:Name="Chip25" Tag="25" Style="{StaticResource PomoChipStyle}" MouseLeftButtonDown="PomoChip_Click" Background="#C69C6D"><TextBlock Text="25m"/></Border><Border x:Name="Chip50" Tag="50" Style="{StaticResource PomoChipStyle}" MouseLeftButtonDown="PomoChip_Click"><TextBlock Text="50m"/></Border><Border x:Name="Chip90" Tag="90" Style="{StaticResource PomoChipStyle}" MouseLeftButtonDown="PomoChip_Click"><TextBlock Text="90m"/></Border></UniformGrid>
                </StackPanel>
                <Grid Grid.Row="2" Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📌 任務標籤" Foreground="#88FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="1" x:Name="PomoLabelInput" Padding="10" Background="#15FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#22FFFFFF" CaretBrush="White" Margin="0,0,0,10"/>
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" Foreground="#88FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="PomoVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="50" VerticalAlignment="Center" ValueChanged="PomoVolumeSlider_ValueChanged"/>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Click="DashPauseBtn_Click" Margin="0,0,6,0" Padding="10,6" Background="#22FFFFFF" Foreground="White" BorderThickness="0" ToolTip="暫停/繼續"><TextBlock x:Name="DashPauseIcon" Text="⏸" FontSize="14"/></Button>
                        <Button Click="DashStopBtn_Click" Margin="0,0,6,0" Padding="10,6" Background="#22FFFFFF" Foreground="White" BorderThickness="0" ToolTip="停止"><TextBlock Text="⏹" FontSize="14"/></Button>
                        <Button Click="StartPomodoro_Click" Padding="14,6" Background="#C69C6D" Foreground="White" BorderThickness="0"><TextBlock Text="🔥 開始" FontWeight="SemiBold"/></Button>
                    </StackPanel>
                </Grid>
                <StackPanel Grid.Row="3">
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="🕒 最近紀錄" Foreground="#AAFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="清除" Click="ClearHistoryBtn_Click" HorizontalAlignment="Right" Padding="8,3" Background="#22FFFFFF" Foreground="#AAFFFFFF" BorderThickness="0" FontSize="11"/>
                    </DockPanel>
                    <ListBox x:Name="PomoHistoryList" Background="Transparent" BorderThickness="0" MaxHeight="120">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,2" CornerRadius="6" Background="#0FFFFFFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding CompletedAtStr}" Foreground="#88FFFFFF" FontSize="10" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
            <Grid x:Name="NotesContainer" Grid.Row="2" Grid.RowSpan="2" Visibility="Collapsed" Margin="10">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="20,15,20,10" Background="{StaticResource Surface1Brush}" CornerRadius="12" Padding="12">
                <StackPanel>
                    <TextBlock Text="全域設定" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="AutoRouteDownloadsCheck" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Cursor="Hand" Checked="AutoRouteDownloads_Checked" Unchecked="AutoRouteDownloads_Checked">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                            <TextBlock Text="📥 自動捕獲下載的圖片/影片到目標框框"/>
                        </StackPanel>
                    </CheckBox>
                    <TextBlock Text="當此功能開啟時，新的下載素材會自動被移動到您選擇的目標框框中。" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" Margin="24,8,0,0" TextWrapping="Wrap"/>
                    <StackPanel x:Name="DownloadTargetPanel" Orientation="Horizontal" Margin="24,8,0,0" Visibility="Collapsed">
                        <TextBlock Text="目標框框：" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="DownloadTargetCombo" Width="150" Margin="8,0,0,0" DisplayMemberPath="Title" SelectedValuePath="Id" SelectionChanged="DownloadTargetCombo_SelectionChanged" Background="{StaticResource Surface2Brush}" Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0" Padding="8,4" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="0,0,0,0" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GlobalNotesList">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6" Width="220" CornerRadius="8" Background="#FFF8E1" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                    <TextBox Text="{Binding Memo}" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="GlobalNoteText_Changed" Tag="{Binding Id}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Grid>
            <Popup x:Name="DashColorPopup" StaysOpen="False" AllowsTransparency="True" Placement="Bottom"><Border Background="#2A2A2A" CornerRadius="8" Padding="8"><WrapPanel x:Name="DashColorPalette" Width="100"/></Border></Popup>
        </Grid>
    </Border>
</Window>
