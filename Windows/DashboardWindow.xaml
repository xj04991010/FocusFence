<Window x:Class="FocusFence.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="FocusFence" ShowInTaskbar="True" Topmost="True"
        Width="500" Height="620" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary Source="/Themes/DesignTokens.xaml"/>
    </Window.Resources>
    <Border CornerRadius="20" BorderThickness="1" Margin="10"
            BorderBrush="{StaticResource ZoneBorderBrush}"
            Effect="{StaticResource ShadowDeep}">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource BgBlurTint}"/>
        </Border.Background>
        <Grid x:Name="MainContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="Auto"/> <!-- Main Tabs -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Border.Background>
                    <LinearGradientBrush>
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel Margin="16,0">
                    <TextBlock x:Name="DashboardTitleText" Text="📊 FocusFence 控制台"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"
                               FontWeight="SemiBold" FontFamily="{StaticResource PrimaryFont}"
                               VerticalAlignment="Center"
                               Typography.StandardLigatures="True"
                               Typography.ContextualLigatures="True"/>
                    <Border DockPanel.Dock="Right" Cursor="Hand"
                            Padding="8,4" CornerRadius="8"
                            MouseLeftButtonDown="Close_Click"
                            HorizontalAlignment="Right"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#33E74C3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="✕" Foreground="#88FFFFFF" FontSize="12"/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Main Tabs -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,10,20,0">
                <Border x:Name="TabZones" Padding="12,6" CornerRadius="6" Background="#33C69C6D" Cursor="Hand" MouseLeftButtonDown="TabZones_Click">
                    <TextBlock x:Name="TabZonesText" Text="🗂️ 框框 (Zones)" Foreground="White" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                </Border>
                <Border x:Name="TabPomodoro" Padding="12,6" Margin="8,0,0,0" CornerRadius="6" Background="Transparent" Cursor="Hand" MouseLeftButtonDown="TabPomodoro_Click">
                    <TextBlock x:Name="TabPomodoroText" Text="🍅 專注打卡 (Focus)" Foreground="#AAFFFFFF" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                </Border>
                <Border x:Name="TabNotes" Padding="12,6" Margin="8,0,0,0" CornerRadius="6" Background="Transparent" Cursor="Hand" MouseLeftButtonDown="TabNotes_Click">
                    <TextBlock x:Name="TabNotesText" Text="📝 任務筆記 (Notes)" Foreground="#AAFFFFFF" FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- ═══ Zones Container ═══ -->
            <Grid x:Name="ZonesContainer" Grid.Row="2" Grid.RowSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="52"/>
                </Grid.RowDefinitions>

                <!-- Zone List (drag-reorder enabled) -->
                <ListBox Grid.Row="0" x:Name="ZoneListBox"
                         Background="Transparent" BorderThickness="0"
                         Margin="12,12,12,4"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="ZoneList_PreviewMouseDown"
                         PreviewMouseMove="ZoneList_PreviewMouseMove"
                         PreviewMouseLeftButtonUp="ZoneList_PreviewMouseUp"
                         Drop="ZoneList_Drop"
                         DragOver="ZoneList_DragOver"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Resources>
                        <!-- Right-click context menu -->
                        <ContextMenu x:Key="ZoneRowContextMenu">
                            <MenuItem Header="呼叫 (帶到前台)" Click="ContextSummon_Click"/>
                            <MenuItem Header="在檔案總管開啟" Click="ContextOpenFolder_Click"/>
                            <Separator/>
                            <MenuItem Header="刪除" Click="ContextDelete_Click"/>
                        </ContextMenu>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ZoneRowBorder" Margin="2" Padding="12,11" CornerRadius="10"
                                    ContextMenu="{StaticResource ZoneRowContextMenu}"
                                    MouseLeftButtonDown="ZoneRow_DoubleClickSummon">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1AFFFFFF"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#25FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Toggle Switch -->
                                    <Border Grid.Column="0" Width="38" Height="20" CornerRadius="10" Cursor="Hand"
                                            Background="{Binding ToggleBackground}" VerticalAlignment="Center"
                                            MouseLeftButtonDown="ToggleSwitch_Click" Tag="{Binding}">
                                        <Ellipse Width="16" Height="16" Fill="White" Margin="{Binding ToggleKnobMargin}"
                                                 HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Ellipse.Effect>
                                                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.3"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Border>

                                    <!-- Color Dot -->
                                    <Ellipse x:Name="DashColorDot" Grid.Column="1" Width="12" Height="12" Fill="{Binding AccentColorBrush}" VerticalAlignment="Center" Cursor="Hand"
                                             MouseLeftButtonDown="DashColorDot_Click" Tag="{Binding}"/>

                                    <!-- Editable Title -->
                                    <TextBox Grid.Column="2" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                             Foreground="#DDFFFFFF" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI"
                                             Background="Transparent" BorderThickness="0" CaretBrush="White" VerticalAlignment="Center"
                                             Margin="6,0,0,0"
                                             InputMethod.IsInputMethodEnabled="True" InputMethod.PreferredImeState="On"
                                             GotFocus="TitleTextBox_GotFocus" LostFocus="TitleTextBox_LostFocus" KeyDown="TitleTextBox_KeyDown"/>

                                    <!-- File Count -->
                                    <TextBlock Grid.Column="3" Text="{Binding FileCount}" Foreground="#44FFFFFF" FontSize="11"
                                               Margin="8,0,10,0" VerticalAlignment="Center"/>

                                    <!-- Delete (clean × icon) -->
                                    <Border Grid.Column="4" Cursor="Hand" VerticalAlignment="Center" Padding="6,4" CornerRadius="4"
                                            MouseLeftButtonDown="RowDeleteX_Click" Tag="{Binding}" ToolTip="刪除">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Opacity" Value="0.4"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#33E74C3C"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="✕" Foreground="#AAFFFFFF" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Drag indicator (shown during drag) -->
                <Border x:Name="DragIndicator" Grid.Row="0" Height="2" Background="#C69C6D"
                        HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        Margin="20,0" Visibility="Collapsed" IsHitTestVisible="False"/>

                <!-- Bottom Buttons -->
                <Border Grid.Row="1" Margin="12,0,12,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="＋ 新增框框" Click="NewZone_Click"
                                Padding="16,8" Margin="4" FontSize="13" FontWeight="SemiBold"
                                Foreground="#CCFFFFFF" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#18FFFFFF" CornerRadius="10" Padding="20,8" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#33C69C6D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✨ 自動排列" Click="AutoArrange_Click"
                                Padding="16,8" Margin="4" FontSize="13" FontWeight="SemiBold"
                                Foreground="#CCFFFFFF" BorderThickness="0" Cursor="Hand"
                                ToolTip="自動將所有框框整齊排列到畫面上">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#18FFFFFF" CornerRadius="10" Padding="20,8" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#335B8DEF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Dashboard Color Settings Popup -->
            <Popup x:Name="DashColorPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border CornerRadius="8" Background="#1E1E1E" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="12" Width="180">
                    <StackPanel>
                        <TextBlock Text="選擇主題顏色" Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="DashColorPalette" Width="160"/>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ═══ Pomodoro Container ═══ -->
            <Grid x:Name="PomodoroContainer" Grid.Row="2" Grid.RowSpan="3" Visibility="Collapsed" Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Active Section -->
                <Border x:Name="PomoActivePanel" Grid.Row="0" CornerRadius="16" Padding="24" Margin="0,0,0,16"
                        Visibility="Collapsed" BorderBrush="#33C69C6D" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2AC69C6D" Offset="0"/>
                            <GradientStop Color="#0AC69C6D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.2" Color="#C69C6D"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="ActiveDashLabel" Text="任務名稱..." Foreground="#FFFFFE" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" TextTrimming="CharacterEllipsis" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        
                        <TextBlock x:Name="ActiveDashTimer" Text="25:00" Foreground="#C69C6D" FontSize="64" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.5" Color="#C69C6D"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border x:Name="DashPauseBtn" Width="48" Height="48" CornerRadius="24" Background="#1AFFFFFF" Margin="0,0,16,0" Cursor="Hand" MouseLeftButtonDown="DashPauseBtn_Click" ToolTip="暫停 / 恢復">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock x:Name="DashPauseIcon" Text="⏸" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <Border x:Name="DashStopBtn" Width="48" Height="48" CornerRadius="24" Background="#26EF5350" Cursor="Hand" MouseLeftButtonDown="DashStopBtn_Click" ToolTip="停止">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4DEF5350"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="✕" FontSize="20" Foreground="#EF5350" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <ProgressBar x:Name="ActiveDashProgress" Height="6" Background="#33FFFFFF" Foreground="#C69C6D" BorderThickness="0" Maximum="100">
                            <ProgressBar.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </ProgressBar.Resources>
                        </ProgressBar>
                    </StackPanel>
                </Border>

                <!-- Input Section -->
                <Border x:Name="PomoInputPanel" Grid.Row="0" CornerRadius="16" Padding="20" Margin="0,0,0,16"
                        BorderBrush="#25FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1AFFFFFF" Offset="0"/>
                            <GradientStop Color="#0AFFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Header -->
                        <DockPanel Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#26C69C6D" VerticalAlignment="Center">
                                <TextBlock Text="🎯" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="開始新任務" Foreground="#FFFFFE" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </DockPanel>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="任務名稱" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <!-- Premium TextBox -->
                            <Border Grid.Column="1" Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10,6">
                                <TextBox x:Name="PomoLabelInput" Background="Transparent" Foreground="#FFFFFE" BorderThickness="0" CaretBrush="#C69C6D" FontSize="14" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="專注深度" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            
                            <!-- Premium Duration Chips (15, 25, 50, 90) -->
                            <UniformGrid Grid.Column="1" Columns="4" Margin="0,0,0,0">
                                <Border x:Name="Chip15" Style="{StaticResource TaskCardContainerStyle}" Tag="15" 
                                        Cursor="Hand" MouseLeftButtonDown="PomoChip_Click" Background="{StaticResource Surface2Brush}" Margin="4,0">
                                    <TextBlock Text="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Chip25" Style="{StaticResource TaskCardContainerStyle}" Tag="25" 
                                        Cursor="Hand" MouseLeftButtonDown="PomoChip_Click" Background="{StaticResource AccentTealBrush}" Margin="4,0">
                                    <TextBlock Text="25" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Chip50" Style="{StaticResource TaskCardContainerStyle}" Tag="50" 
                                        Cursor="Hand" MouseLeftButtonDown="PomoChip_Click" Background="{StaticResource Surface2Brush}" Margin="4,0">
                                    <TextBlock Text="50" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Chip90" Style="{StaticResource TaskCardContainerStyle}" Tag="90" 
                                        Cursor="Hand" MouseLeftButtonDown="PomoChip_Click" Background="{StaticResource Surface2Brush}" Margin="4,0">
                                    <TextBlock Text="90" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </UniformGrid>
                        </Grid>
                        <!-- Volume Control -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="環境音量" Foreground="#B3FFFFFF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Slider x:Name="PomoVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="50" 
                                    VerticalAlignment="Center" Margin="8,0,12,0"
                                    ValueChanged="PomoVolumeSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" Text="{Binding Value, ElementName=PomoVolumeSlider, StringFormat=\{0\}%}" 
                                       Foreground="{StaticResource AccentTealBrush}" FontSize="12" FontWeight="Bold" 
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Start Button -->
                        <Button Content="▶ 開始番茄鐘" Click="StartPomodoro_Click" Cursor="Hand" Height="44" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="10" Background="#C69C6D">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="#C69C6D"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Border CornerRadius="10" Background="#22000000" x:Name="HoverOverlay" Opacity="0"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="▶" Foreground="#1A1A1A" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="開始番茄鐘" Foreground="#1A1A1A" FontWeight="Bold" FontSize="15" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="150" CenterY="22"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.RenderTransform>
                                <ScaleTransform/>
                            </Button.RenderTransform>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Stats Section -->
                <Border Grid.Row="1" CornerRadius="12" Padding="20,16" Margin="0,0,0,16" BorderBrush="#1AFFFFFF" BorderThickness="1" Background="#0AFFFFFF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="🎯" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Text="本週目標" Foreground="#E6FFFFFF" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>
                        
                        <ProgressBar x:Name="WeekTomatoProgressBar" Grid.Column="1" Height="6" Maximum="21" Value="0" 
                                     Background="#1AFFFFFF" Foreground="#C69C6D" BorderThickness="0" VerticalAlignment="Center"
                                     ToolTip="21 個番茄鐘">
                            <ProgressBar.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </ProgressBar.Resources>
                        </ProgressBar>
                                     
                        <Border Grid.Column="2" Background="#1AC69C6D" CornerRadius="12" Padding="12,4" Margin="12,0,0,0">
                            <TextBlock x:Name="WeekTomatoCountText" Text="0 / 21" 
                                       Foreground="#C69C6D" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- History Section -->
                <Border Grid.Row="2" CornerRadius="16" Padding="20" BorderBrush="#1AFFFFFF" BorderThickness="1" Background="#0CFFFFFF">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,16">
                            <Border Width="28" Height="28" CornerRadius="8" Background="#1AFFFFFF" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="📜" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <Button x:Name="ClearHistoryBtn" Click="ClearHistoryBtn_Click" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="4" Padding="6,2" x:Name="bgBorder">
                                            <TextBlock Text="清空" Foreground="#A3FFFFFF" FontSize="12" FontFamily="Segoe UI" x:Name="txt"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bgBorder" Property="Background" Value="#22EF5350"/>
                                                <Setter TargetName="txt" Property="Foreground" Value="#EF5350"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <TextBlock Text="最近歷史紀錄" Foreground="#FFFFFE" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>
                        
                        <ListBox Grid.Row="1" x:Name="PomoHistoryList" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="16,12" CornerRadius="10" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#0AFFFFFF" Offset="0"/>
                                                <GradientStop Color="#03FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#1A000000" CornerRadius="6" Padding="8,4" Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CompletedAt, StringFormat=HH:mm}" Foreground="#A3FFFFFF" FontSize="12" FontFamily="Consolas" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" Foreground="#FFFFFE" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ZoneTitle}" Foreground="#80FFFFFF" FontSize="12"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="#1AC69C6D" CornerRadius="6" Padding="8,6" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DurationStr}" Foreground="#C69C6D" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Notes / Tasks Container ═══ -->
            <Grid x:Name="NotesContainer" Grid.Row="2" Grid.RowSpan="3" Visibility="Collapsed" Margin="12,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" CornerRadius="12" Background="#1AFFFFFF" Padding="16,12" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock Text="📝 專案總覽便利貼" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="整合所有框框的任務筆記" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </DockPanel>
                </Border>
                
                <!-- WrapPanel for Sticky Notes -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="GlobalNotesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Sticky Note (Dashboard View) -->
                                <Border Margin="6" Width="220" MinHeight="150" CornerRadius="8"
                                        Background="#FFF8E1" Padding="12,12,12,16">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.15" Color="Black"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Zone Title Header -->
                                        <Border Grid.Row="0" BorderBrush="#22000000" BorderThickness="0,0,0,1" Padding="0,0,0,6" Margin="0,0,0,6">
                                            <DockPanel>
                                                <Border Width="10" Height="10" CornerRadius="5" Background="{Binding AccentColorBrush}" VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <!-- Use same AccentColor converter or just fallback to generic if complex, here we just bind to hex but need a brush. We will provide AccentColorBrush property in ZoneConfig. -->
                                                </Border>
                                                <TextBlock Text="{Binding Title}" Foreground="#8C7949" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                        </Border>
                                        
                                        <!-- Memo Editor -->
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding Memo, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent"
                                                 Foreground="#6B5935"
                                                 BorderThickness="0"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 FontSize="13"
                                                 FontFamily="{DynamicResource PrimaryFont}"
                                                 CaretBrush="#8C7949"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextChanged="GlobalNoteText_Changed"
                                                 Tag="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Bottom Bar with Global Actions -->
            <Grid Grid.Row="4" Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FocusFence v5.0 Designer Edition" Foreground="#66FFFFFF" FontSize="10" VerticalAlignment="Center" Opacity="0.5"/>
                </StackPanel>

                <Button Grid.Column="1" Click="PinToTaskbar_Click" 
                        Padding="12,4" Height="30" Cursor="Hand"
                        Background="#11FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛠️" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="打包並固定到工具列" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
