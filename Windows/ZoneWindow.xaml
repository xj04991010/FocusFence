<Window x:Class="FocusFence.Windows.ZoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:FocusFence.Controls"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True" Topmost="False" ResizeMode="NoResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <ContextMenu x:Key="FileContextMenu">
            <MenuItem Header="開啟" Click="Context_Open"/>
            <MenuItem Header="複製路徑" Click="Context_CopyPath"/>
            <MenuItem Header="在檔案總管開啟" Click="Context_ShowInExplorer"/>
            <Separator/>
            <MenuItem Header="新增資料夾" Click="Context_NewFolder"/>
            <MenuItem Header="新增文字檔 (.txt)" Click="Context_NewTextFile"/>
            <Separator/>
            <MenuItem Header="📂 整理子資料夾影片到此處" Click="Context_ConsolidateVideos"/>
            <MenuItem Header="📦 解壓縮 (Extract)" Click="Context_Extract"/>
            <Separator/>
            <MenuItem Header="重新命名 (F2)" Click="Context_Rename"/>
            <MenuItem Header="✏️ 批次重新命名" Click="Context_BatchRename"/>
            <MenuItem Header="刪除" Click="Context_Delete"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════════════════════
             PART 3A: Three-Layer Soft Shadow System
             From outer (diffuse) to inner (contact), each layer adds
             depth without the harsh single-DropShadow look.
             ═══════════════════════════════════════════════════════════ -->

        <!-- Shadow Layer 3: Far shadow — large radius, very faint -->
        <!-- Shadow Layer 3: Far shadow — large radius, very faint -->
        <Border x:Name="ShadowLayer3" Margin="5"
                CornerRadius="18"
                Opacity="{DynamicResource ShadowLayer3Opacity}"
                Background="Black" IsHitTestVisible="False">
            <Border.Effect>
                <BlurEffect Radius="20"/>
            </Border.Effect>
        </Border>

        <!-- Shadow Layer 2: Mid shadow — floaty feel -->
        <Border x:Name="ShadowLayer2" Margin="7"
                CornerRadius="15"
                Opacity="{DynamicResource ShadowLayer2Opacity}"
                Background="Black" IsHitTestVisible="False">
            <Border.Effect>
                <BlurEffect Radius="10"/>
            </Border.Effect>
        </Border>

        <!-- Shadow Layer 1: Contact shadow — subtle Y offset -->
        <Border x:Name="ShadowLayer1" Margin="8,10,8,6"
                CornerRadius="13"
                Opacity="{DynamicResource ShadowLayer1Opacity}"
                Background="Black" IsHitTestVisible="False">
            <Border.Effect>
                <BlurEffect Radius="4"/>
            </Border.Effect>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             PART 2B: Apple-style Highlight Border
             Gradient from top-left highlight to bottom-right shadow.
             1px border, never scales with DPI (UseLayoutRounding=True).
             ═══════════════════════════════════════════════════════════ -->
        <Border x:Name="MainBorder"
                CornerRadius="{DynamicResource RadiusZone}"
                BorderThickness="1" Margin="10"
                BorderBrush="{DynamicResource ZoneBorderBrush}"
                Background="#DD1A1A1A"
                ClipToBounds="True"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ZoneScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="ZoneTranslate" Y="0"/>
                </TransformGroup>
            </Border.RenderTransform>

            <Grid>
                <!-- ═══ PART 2A Layer 2: Tint Overlay ═══ -->
                <Border x:Name="TintOverlay"
                        CornerRadius="11"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush Color="White" Opacity="0.04"/>
                    </Border.Background>
                </Border>

                <!-- ═══ PART 2A Layer 3: Noise Texture ═══ -->
                <Border x:Name="NoiseOverlay"
                        CornerRadius="11"
                        IsHitTestVisible="False"
                        Opacity="0.06"/>

                <!-- ═══ Active Context Glow (PART 7A) ═══ -->
                <Border x:Name="ContextGlowBorder"
                        CornerRadius="{DynamicResource RadiusZone}"
                        BorderThickness="0"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource AccentTeal}"/>
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource AccentTealGlow}"
                                          BlurRadius="16" ShadowDepth="0" Opacity="0.6"/>
                    </Border.Effect>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{DynamicResource TitleBarHeight}"/>
                        <RowDefinition Height="Auto"/>  <!-- Breadcrumb -->
                        <RowDefinition Height="Auto"/>  <!-- Search -->
                        <RowDefinition Height="Auto"/>  <!-- Large Pomodoro -->
                        <RowDefinition Height="Auto"/>  <!-- Task Cards -->
                        <RowDefinition Height="Auto"/>  <!-- Dormancy -->
                        <RowDefinition Height="*"/>     <!-- Content -->
                    </Grid.RowDefinitions>

                    <!-- ═══ Title Bar (32px per PART 6B) ═══ -->
                    <Border Grid.Row="0"
                            CornerRadius="{DynamicResource RadiusTitleBar}"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            MouseRightButtonDown="TitleBar_RightClick">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#10FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel Margin="8,0">

                            <!-- Pomodoro Ring (PART 7C) -->
                            <ctrl:PomodoroRing x:Name="PomodoroRing"
                                               DockPanel.Dock="Left"
                                               Margin="0,0,8,0"
                                               Width="{DynamicResource PomodoroRingSize}"
                                               Height="{DynamicResource PomodoroRingSize}"
                                               Visibility="Collapsed"
                                               Cursor="Hand"
                                               PreviewMouseLeftButtonDown="PomodoroIndicator_Click"
                                               ToolTip="開始專注"/>

                            <!-- Right-side controls -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- File count badge -->
                                <TextBlock x:Name="FileCountText"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSizeFileCount}"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           Typography.NumeralAlignment="Tabular"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>

                                <!-- Pomodoro Start -->
                                <Border Style="{DynamicResource TitleBarBtnStyle}"
                                        PreviewMouseLeftButtonDown="PomodoroBtn_Click"
                                        ToolTip="開始番茄鐘">
                                    <TextBlock x:Name="PomodoroIcon" Text="&#xE916;"
                                               FontFamily="{DynamicResource IconFont}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="12"/>
                                </Border>

                                <!-- Pin -->
                                <Border Style="{DynamicResource TitleBarBtnStyle}"
                                        PreviewMouseLeftButtonDown="PinBtn_Click">
                                    <TextBlock x:Name="PinIcon" Text="&#xE718;"
                                               FontFamily="{DynamicResource IconFont}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="12"/>
                                </Border>

                                <!-- Collapse -->
                                <Border Style="{DynamicResource TitleBarBtnStyle}"
                                        PreviewMouseLeftButtonDown="CollapseBtn_Click">
                                    <TextBlock x:Name="CollapseIcon" Text="&#xE70D;"
                                               FontFamily="{DynamicResource IconFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="10"/>
                                </Border>

                                <!-- Close -->
                                <Border Style="{DynamicResource CloseBtnStyle}"
                                        PreviewMouseLeftButtonDown="CloseBtn_Click" Margin="2,0,0,0">
                                    <TextBlock Text="&#xE8BB;"
                                               FontFamily="{DynamicResource IconFont}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="10"/>
                                </Border>
                            </StackPanel>

                            <!-- Title (read) -->
                            <TextBlock x:Name="TitleText" Text="Zone"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="{DynamicResource FontSizeZoneTitle}"
                                       FontWeight="SemiBold"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       VerticalAlignment="Center"
                                       PreviewMouseLeftButtonDown="TitleText_MouseDown"/>
                            <!-- Title (edit) -->
                            <TextBox x:Name="TitleEdit" Visibility="Collapsed"
                                     Background="{DynamicResource Surface2Brush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="White" BorderThickness="0"
                                     FontSize="{DynamicResource FontSizeZoneTitle}"
                                     FontWeight="SemiBold"
                                     FontFamily="{DynamicResource PrimaryFont}"
                                     VerticalAlignment="Center" Padding="4,2"
                                     KeyDown="TitleEdit_KeyDown" LostFocus="TitleEdit_LostFocus"/>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Task Progress Bar (2px per PART 6B, flush to title bottom) ═══ -->
                    <Border x:Name="TaskProgressBar" Grid.Row="0"
                            Height="{DynamicResource ProgressBarHeight}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left" Width="0"
                            CornerRadius="{DynamicResource RadiusProgressBar}"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <SolidColorBrush Color="{DynamicResource AccentTeal}"/>
                        </Border.Background>
                    </Border>

                    <!-- ═══ Breadcrumb ═══ -->
                    <Border x:Name="BreadcrumbBar" Grid.Row="1"
                            Margin="12,4,12,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Border Cursor="Hand" Padding="6,4"
                                    CornerRadius="{DynamicResource RadiusCardInner}"
                                    MouseLeftButtonDown="NavigateBack_Click"
                                    Background="{DynamicResource Surface1Brush}">
                                <TextBlock Text="&#xE72B; 返回"
                                           FontFamily="{DynamicResource IconFont}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSizeTooltip}"/>
                            </Border>
                            <TextBlock x:Name="BreadcrumbText"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="{DynamicResource FontSizeTooltip}"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Search Bar ═══ -->
                    <Border x:Name="SearchBar" Grid.Row="2"
                            Margin="12,4,12,0" Padding="8,4"
                            CornerRadius="{DynamicResource RadiusCard}"
                            Background="{DynamicResource Surface1Brush}"
                            Visibility="Collapsed">
                        <DockPanel>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="{DynamicResource IconFont}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"
                                       Margin="0,0,8,0" DockPanel.Dock="Left"/>
                            <Border DockPanel.Dock="Right" Cursor="Hand"
                                    Padding="4,2" CornerRadius="{DynamicResource RadiusCardInner}"
                                    MouseLeftButtonDown="SearchClear_Click"
                                    Style="{DynamicResource TitleBarBtnStyle}">
                                <TextBlock Text="&#xE8BB;"
                                           FontFamily="{DynamicResource IconFont}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="9"/>
                            </Border>
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="White" BorderThickness="0"
                                     FontSize="{DynamicResource FontSizeTaskCard}"
                                     FontFamily="{DynamicResource PrimaryFont}"
                                     VerticalAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"/>
                        </DockPanel>
                    </Border>



                    <!-- ═══ Sort Bar ═══ -->
                    <Border x:Name="SortBar" Grid.Row="2"
                            Margin="12,6,12,0" Visibility="{Binding ElementName=ContentArea, Path=Visibility}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="排序:" Foreground="{DynamicResource TextTertiaryBrush}" 
                                       FontSize="11" FontFamily="{DynamicResource PrimaryFont}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border x:Name="SortByName" Cursor="Hand" Padding="6,3" CornerRadius="4" Margin="2,0"
                                    Background="#22FFFFFF" MouseLeftButtonDown="SortByName_Click">
                                <TextBlock Text="名稱" Foreground="#AAFFFFFF" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"/>
                            </Border>
                            <Border x:Name="SortByDate" Cursor="Hand" Padding="6,3" CornerRadius="4" Margin="2,0"
                                    Background="Transparent" MouseLeftButtonDown="SortByDate_Click">
                                <TextBlock Text="日期" Foreground="#66FFFFFF" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"/>
                            </Border>
                            <Border x:Name="SortByType" Cursor="Hand" Padding="6,3" CornerRadius="4" Margin="2,0"
                                    Background="Transparent" MouseLeftButtonDown="SortByType_Click">
                                <TextBlock Text="類型" Foreground="#66FFFFFF" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"/>
                            </Border>
                            <Border x:Name="SortBySize" Cursor="Hand" Padding="6,3" CornerRadius="4" Margin="2,0"
                                    Background="Transparent" MouseLeftButtonDown="SortBySize_Click">
                                <TextBlock Text="大小" Foreground="#66FFFFFF" FontSize="11" FontFamily="{DynamicResource PrimaryFont}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Dormancy Badge (PART 7A) ═══ -->
                    <Border x:Name="DormancyBadge" Grid.Row="5"
                            Margin="12,4,12,0" Visibility="Collapsed"
                            Padding="{DynamicResource BadgePadding}"
                            CornerRadius="{DynamicResource RadiusBadge}"
                            Background="{DynamicResource Surface1Brush}"
                            Cursor="Hand" MouseLeftButtonDown="DormancyBadge_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEA8F;"
                                       FontFamily="{DynamicResource IconFont}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="11" Margin="0,0,4,0"/>
                            <TextBlock x:Name="DormancyText" Text="休眠中"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="{DynamicResource FontSizeDormancy}"
                                       FontFamily="{DynamicResource PrimaryFont}"/>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Content Area ═══ -->
                    <Border x:Name="ContentArea" Grid.Row="6"
                            Margin="{DynamicResource ZonePadding}"
                            CornerRadius="{DynamicResource RadiusCard}"
                            ClipToBounds="True">
                        <Border.Background>
                            <SolidColorBrush Color="Black" Opacity="0.10"/>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="PlaceholderText" Text="拖曳檔案到此處..."
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="{DynamicResource FontSizeTaskCard}"
                                       FontFamily="{DynamicResource PrimaryFont}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Grid.Row="0" Panel.ZIndex="0"/>

                            <ListBox x:Name="FileListBox" Background="Transparent"
                                     Grid.Row="0"
                                     BorderThickness="0" SelectionMode="Extended"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ContextMenu="{StaticResource FileContextMenu}"
                                     PreviewMouseRightButtonDown="FileList_PreviewRightClick"
                                     MouseDoubleClick="FileList_DoubleClick"
                                     PreviewMouseLeftButtonDown="FileList_PreviewMouseDown"
                                     PreviewMouseMove="FileList_PreviewMouseMove"
                                     PreviewMouseLeftButtonUp="FileList_PreviewMouseLeftButtonUp"
                                     KeyDown="FileList_KeyDown"
                                     Panel.ZIndex="1">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemBoxWidth}"
                                                Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemBoxHeight}"
                                                Margin="4"
                                                Style="{DynamicResource FileItemHoverStyle}"
                                                ToolTip="{Binding FileName}">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <!-- Thumbnail or Icon -->
                                                <Grid HorizontalAlignment="Center">
                                                    <!-- Thumbnail image (shown when HasThumbnail is true) -->
                                                    <Border CornerRadius="4" ClipToBounds="True"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IconSize}"
                                                            Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IconSize}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <!-- Fallback icon (shown when HasThumbnail is false) -->
                                                    <TextBlock Text="{Binding IconEmoji}"
                                                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IconSize}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontFamily="{DynamicResource IconFont}"
                                                               HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <Grid Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemFontSize}"
                                                               FontFamily="{DynamicResource PrimaryFont}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center"
                                                               MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemTextWidth}"
                                                               MaxHeight="30" LineHeight="14"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    
                                                    <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="#CC000000" Foreground="White" BorderThickness="0"
                                                             TextAlignment="Center" Padding="2"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             MinWidth="100" InputMethod.IsInputMethodEnabled="True" InputMethod.PreferredImeState="On"
                                                             MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ItemTextWidth}"
                                                             Loaded="RenameTextBox_Loaded"
                                                             KeyDown="RenameTextBox_KeyDown"
                                                             LostFocus="RenameTextBox_LostFocus">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <StaticResource ResourceKey="ZoneListBoxItemStyle"/>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <!-- Rubber band selection canvas -->
                            <Canvas Grid.Row="0" Panel.ZIndex="10" IsHitTestVisible="False">
                                <Border x:Name="SelectionRect"
                                        Background="#335B8DEF" BorderBrush="#5B8DEF" BorderThickness="1"
                                        Visibility="Collapsed" />
                            </Canvas>

                            <!-- Sticky Note (Windows Sticky Notes style) -->
                            <Border x:Name="StickyNoteArea" Grid.Row="1" Margin="6,0,6,6"
                                    MinHeight="36" MaxHeight="120"
                                    CornerRadius="6" Panel.ZIndex="1"
                                    Background="#FFF2AB">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.2" Color="Black"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="8,6,8,0">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#E5C743" VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                                        <TextBlock Text="便利貼"
                                                   Foreground="#947A11" FontSize="11" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource PrimaryFont}"
                                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    </DockPanel>
                                    <TextBox x:Name="ZoneMemo" Grid.Row="1"
                                             Background="Transparent"
                                             Foreground="#4A3B05"
                                             BorderThickness="0"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             Padding="8,4,8,8"
                                             FontSize="13"
                                             FontFamily="{DynamicResource PrimaryFont}"
                                             CaretBrush="#4A3B05"
                                             VerticalScrollBarVisibility="Auto"
                                             ToolTip="專案便利貼 (自動儲存)"
                                             TextChanged="ZoneMemo_TextChanged"/>
                                </Grid>
                            </Border>

                            <!-- ═══ Large Centered Zone Title (Fences-style) + Settings trigger ═══ -->
                            <Border x:Name="ZoneLabelArea" Grid.Row="2" Padding="4,4,4,6"
                                    CornerRadius="0,0,6,6" Cursor="Hand"
                                    MouseLeftButtonDown="ZoneLabel_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop x:Name="LabelGradient1" Color="#00000000" Offset="0"/>
                                        <GradientStop x:Name="LabelGradient2" Color="#18000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="ZoneLabelText"
                                           Foreground="#66FFFFFF"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           FontFamily="{DynamicResource PrimaryFont}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="點此調整框框設定"/>
                            </Border>

                            <!-- Resize Grip -->
                            <Path x:Name="ResizeGripCanvas" Grid.Row="2"
                                  Data="M 12,0 L 12,12 L 0,12 Z"
                                  Fill="{DynamicResource TextTertiaryBrush}"
                                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                  Width="12" Height="12" Margin="0,0,2,2"
                                  Cursor="SizeNWSE" Panel.ZIndex="2"
                                  MouseLeftButtonDown="ResizeGrip_MouseDown"
                                  MouseMove="ResizeGrip_MouseMove"
                                  MouseLeftButtonUp="ResizeGrip_MouseUp">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Fill"
                                                        Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ Settings Popup ═══ -->
        <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=ZoneLabelArea}"
               Placement="Top" StaysOpen="False" AllowsTransparency="True"
               Opened="ColorPopup_Opened">
            <Border CornerRadius="{DynamicResource RadiusZone}"
                    BorderBrush="{DynamicResource ZoneBorderBrush}" BorderThickness="1"
                    Padding="12" Width="200">
                <Border.Background>
                    <SolidColorBrush Color="#1E1E1E" Opacity="0.95"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="主題顏色"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeTooltip}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               Margin="0,0,0,8"/>
                    <WrapPanel x:Name="ColorPalette" Width="180"/>

                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,12,0,12"/>

                    <TextBlock Text="背景透明度"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeTooltip}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               Margin="0,0,0,8"/>
                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0"
                            TickFrequency="0.1" IsSnapToTickEnabled="False"
                            ValueChanged="OpacitySlider_ValueChanged"/>

                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,12,0,12"/>

                    <TextBlock Text="圖示大小"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeTooltip}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               Margin="0,0,0,8"/>
                    <Slider x:Name="IconSizeSlider" Minimum="20" Maximum="80"
                            TickFrequency="4" IsSnapToTickEnabled="True"
                            ValueChanged="IconSizeSlider_ValueChanged"/>
                            
                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,12,0,12"/>

                    <CheckBox x:Name="HoverExpandCheck" Content="滑鼠懸停自動展開"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="{DynamicResource FontSizeTooltip}"
                              FontFamily="{DynamicResource PrimaryFont}"
                              Margin="0,0,0,6"
                              Checked="HoverExpand_Checked" Unchecked="HoverExpand_Checked"/>

                    <CheckBox x:Name="ShowMemoCheck" Content="顯示便利貼"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              FontSize="{DynamicResource FontSizeTooltip}"
                              FontFamily="{DynamicResource PrimaryFont}"
                              Margin="0,0,0,6"
                              Checked="ShowMemo_Checked" Unchecked="ShowMemo_Checked"/>

                    <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,6,0,12"/>

                    <TextBlock Text="番茄鐘時長 (分鐘)"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeTooltip}"
                               FontFamily="{DynamicResource PrimaryFont}"
                               Margin="0,0,0,8"/>
                    <Slider x:Name="PomodoroDurationSlider" Minimum="5" Maximum="60"
                            TickFrequency="5" IsSnapToTickEnabled="True" Value="25"
                            ValueChanged="PomodoroDuration_ValueChanged"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
