<Window x:Class="FocusFence.Windows.PomodoroTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Width="280" Height="110"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Deactivated="Window_Deactivated"
        LocationChanged="Window_LocationChanged"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ResourceDictionary Source="/Themes/DesignTokens.xaml"/>
    </Window.Resources>
    <Border x:Name="MainBorder" CornerRadius="{StaticResource RadiusZone}"
            BorderThickness="1" Padding="14,12" Margin="10"
            AutomationProperties.Name="番茄鐘計時器">
        <Border.Background>
            <SolidColorBrush Color="{StaticResource BgBlurTint}"/>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="{StaticResource BorderHighlight}" Opacity="0.35"/>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <Grid x:Name="RootGrid" Background="Transparent">
            <!-- Fade-on-Hover Animations -->
            <Grid.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HeaderGrid" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="HeaderGrid" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header bar (HIDDEN by default, fades in on hover) -->
            <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,8" Opacity="0">
                <TextBlock x:Name="TaskLabelText" Text="專注中..." 
                           Foreground="{StaticResource TextPrimaryBrush}" 
                           FontSize="11" FontWeight="SemiBold" Opacity="0.6"
                           FontFamily="{StaticResource PrimaryFont}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                
                <StackPanel x:Name="AuxControls" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="WhiteNoiseBtn" Cursor="Hand" MouseLeftButtonDown="WhiteNoiseBtn_Click" Margin="0,0,6,0">
                        <TextBlock Text="&#xE767;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="White" Opacity="0.4" x:Name="WhiteNoiseIcon"/>
                    </Border>
                    <Border x:Name="BrownNoiseBtn" Cursor="Hand" MouseLeftButtonDown="BrownNoiseBtn_Click" Margin="0,0,10,0">
                        <TextBlock Text="&#xE767;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="#C69C6D" Opacity="0.4" x:Name="BrownNoiseIcon"/>
                    </Border>
                    <Border x:Name="VolumeBtn" Cursor="Hand" MouseLeftButtonDown="VolumeBtn_Click" Margin="0,0,10,0">
                        <TextBlock Text="&#xE767;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="White" Opacity="0.4"/>
                    </Border>
                    
                    <Popup x:Name="VolumePopup" PlacementTarget="{Binding ElementName=VolumeBtn}" 
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#222222" CornerRadius="8" BorderBrush="#33FFFFFF" 
                                BorderThickness="1" Padding="10,6" Width="140">
                            <Slider x:Name="LocalVolumeSlider" Minimum="0" Maximum="100" Value="50"
                                    ValueChanged="LocalVolumeSlider_ValueChanged" VerticalAlignment="Center"/>
                        </Border>
                    </Popup>

                    <Border x:Name="PauseBtn" Cursor="Hand" MouseLeftButtonDown="PauseBtn_Click" Margin="0,0,10,0">
                        <TextBlock x:Name="PauseIcon" Text="⏸" FontSize="11" Foreground="White" Opacity="0.7"/>
                    </Border>
                    <Border x:Name="StopBtn" Cursor="Hand" MouseLeftButtonDown="StopBtn_Click">
                        <TextBlock Text="✕" FontSize="11" Foreground="{StaticResource DestructiveBrush}" Opacity="0.7"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Timer (Neon Glow Style) -->
            <Viewbox Grid.Row="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TimerText" Text="25:00" 
                           Foreground="#5EEAD4" FontSize="56" FontWeight="Bold" 
                           FontFamily="Segoe UI Variable Display" 
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#5EEAD4" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Viewbox>

            <!-- Progress Bar (Sleek Gradient Beam) -->
            <ProgressBar x:Name="ProgressArc" Grid.Row="2" Height="2" Margin="0,12,0,0" 
                          Background="#0AFFFFFF" BorderThickness="0" Maximum="100">
                <ProgressBar.Resources>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border Background="{TemplateBinding Background}">
                                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#5EEAD4" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#5EEAD4" Opacity="0.9"/>
                                            </Border.Effect>
                                        </Border>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>
        </Grid>
    </Border>
</Window>
